# ==============================================================================
# STOCK BATTLE ROYALE - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and customize for your environment
# For Docker deployment, all variables below are used by docker-compose.yml

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# PostgreSQL database settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_DB=stock_battle_royale

# PostgreSQL port mapping (host:container)
# Default: 5432:5432
# Change if port 5432 is already in use on host
POSTGRES_PORT=5432

# Database connection URL
# For local development (outside Docker):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stock_battle_royale?schema=public"
# For Docker (constructed automatically, no need to change):
# DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

# ==============================================================================
# APPLICATION PORTS
# ==============================================================================
# Backend API internal port (inside container)
# Change only if you need the app to listen on a different port internally
PORT=3000

# Backend API external port (host machine)
# This is what you'll use to access the API: http://localhost:BACKEND_PORT
BACKEND_PORT=3000

# Frontend external port (host machine)
# This is what you'll use to access the UI: http://localhost:CLIENT_PORT
CLIENT_PORT=80

# Frontend API URL (for browser requests to backend)
# This is baked into the frontend build and tells the browser where to find the API
# Format: http://localhost:BACKEND_PORT/api
VITE_API_URL=http://localhost:3000/api

# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================
# JWT Secret for authentication tokens
# CRITICAL: Change this in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-in-production-use-openssl-rand-base64-32

# Node environment (development, production, test)
NODE_ENV=production

# Docker Compose profile — controls which stack starts with 'docker compose up'
#   prod  → full stack (db + backend + frontend)
#   demo  → single self-contained demo container (no DB or Ollama required)
COMPOSE_PROFILES=prod

# CORS allowed origin for the API server
# Set to the URL of your frontend in production (e.g. https://yourdomain.com)
# Leave empty to allow all origins (development default)
CORS_ORIGIN=

# ==============================================================================
# OLLAMA CONFIGURATION
# ==============================================================================
# Ollama server URL - Configure based on your setup:
#
# Option 1: Ollama on host machine (Docker Desktop/Linux)
#   Use this for local development when Ollama runs on your computer
OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# Option 2: External Ollama server
#   Use when Ollama runs on a different machine
#   OLLAMA_BASE_URL=http://192.168.1.100:11434
#
# Option 3: Ollama in same Docker network (advanced)
#   If you run Ollama in Docker alongside this app
#   OLLAMA_BASE_URL=http://ollama:11434
#
# Option 4: Local development (outside Docker)
#   OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use for AI trading bots
# Available models: llama3.2, llama3.1, mistral, etc.
# Run 'ollama list' to see installed models
OLLAMA_MODEL=llama3.2

# ==============================================================================
# BOT CONFIGURATION
# ==============================================================================
# Bot execution interval in milliseconds
# How often the system checks for and executes active trading bots
# Default: 30000 (30 seconds)
# Recommended range: 15000-60000 (15 seconds to 1 minute)
BOT_EXECUTION_INTERVAL=30000

# ==============================================================================
# DOCKER CONFIGURATION SUMMARY
# ==============================================================================
# When using docker-compose:
#
# Access URLs:
#   Frontend:  http://localhost:${CLIENT_PORT}
#   Backend:   http://localhost:${BACKEND_PORT}
#   Database:  localhost:${POSTGRES_PORT}
#
# Port Mappings:
#   CLIENT_PORT:80        - Frontend (Nginx)
#   BACKEND_PORT:PORT     - Backend API
#   POSTGRES_PORT:5432    - PostgreSQL
#
# All variables above are automatically passed to Docker containers.
# Changes require restart: docker-compose down && docker-compose up -d
# ==============================================================================
